<view class="container">
  <!-- 录入接龙 -->
  <view class="card" wx:if="{{isAdmin}}">
    <view class="card-title">📝 粘贴接龙内容</view>
    <textarea
      class="input-area"
      placeholder="从微信群复制接龙内容粘贴到这里&#10;&#10;例如：&#10;6月2日 周五羽毛球接龙&#10;1. 1号场 8-10&#10;2. 张三(zhangsan)&#10;3. 李四(lisi123)&#10;4. 王五&#10;&#10;自动识别日期、跳过场地行、去掉时间段"
      value="{{signupText}}"
      bindinput="onInput"
      maxlength="5000"
      auto-height
    />
    <view class="btn-row btn-center">
      <button class="btn btn-primary" bindtap="submit" loading="{{submitting}}">✅ 保存接龙</button>
      <button class="btn btn-outline" bindtap="clearInput">清空</button>
    </view>
  </view>

  <!-- 解析结果预览 -->
  <view class="card" wx:if="{{parsedNames.length > 0 || parsedDate}}">
    <view class="card-title">🔍 解析结果</view>
    <view class="result-row" wx:if="{{parsedDate}}">
      <text class="result-label">日期：</text>
      <text class="result-value">{{parsedDate}}</text>
    </view>
    <view class="result-row">
      <text class="result-label">参与：</text>
      <text class="result-value">{{parsedNames.length}} 人</text>
    </view>
    <view class="tag-list">
      <view class="tag" wx:for="{{parsedNames}}" wx:key="*this">{{item}}</view>
    </view>
  </view>

  <!-- 最近接龙记录 -->
  <view class="card">
    <view class="card-title">📋 最近接龙记录</view>
    <view wx:if="{{loading}}" class="loading">加载中...</view>
    <view wx:if="!loading && records.length === 0" class="empty">暂无记录，录入第一条吧 🏸</view>

    <view class="record-list" wx:if="records.length > 0">
      <view class="record-item" wx:for="{{records}}" wx:key="_id" bindtap="viewRecord" data-record="{{item}}">
        <view class="record-date">{{item.date}}</view>
        <view class="record-signups">{{item.previewText}}</view>
        <view class="record-delete" wx:if="{{isAdmin}}" bindtap="deleteRecord" data-id="{{item._id}}" data-date="{{item.date}}">删除</view>
      </view>
    </view>
    <view class="card" wx:if="{{!isAdmin && records.length === 0}}">
    <view class="empty-tip">⏳ 等待管理员录入接龙数据...</view>
  </view>

  <view class="toast {{showToast ? 'toast-show' : ''}}">{{toastMsg}}</view>
</view>
