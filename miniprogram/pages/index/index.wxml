<view class="container">
  <!-- 录入接龙 -->
  <view class="card">
    <view class="card-title">📝 录入接龙</view>
    <view class="form-row">
      <text class="form-label">日期</text>
      <picker mode="date" value="{{signupDate}}" bindchange="onDateChange">
        <view class="picker">{{signupDate || '点击选择日期'}}</view>
      </picker>
    </view>
    <textarea
      class="input-area"
      placeholder="从微信群复制接龙内容粘贴到这里&#10;&#10;支持格式：&#10;1. 张三(zhangsan)&#10;2. 李四(lisi123)&#10;3. 王五&#10;&#10;自动去掉时间段如 8-10、8～10、8点 等"
      value="{{signupText}}"
      bindinput="onInput"
      maxlength="5000"
      auto-height
    />
    <view class="btn-row">
      <button class="btn btn-primary" bindtap="submit" loading="{{submitting}}">✅ 保存接龙</button>
      <button class="btn btn-outline" bindtap="clearInput">清空</button>
    </view>
  </view>

  <!-- 解析结果预览 -->
  <view class="card" wx:if="{{parsedNames.length > 0}}">
    <view class="card-title">🔍 解析结果</view>
    <view class="result-info">
      <text>共 <text class="highlight">{{parsedNames.length}}</text> 人参与</text>
    </view>
    <view class="tag-list">
      <view class="tag" wx:for="{{parsedNames}}" wx:key="*this">{{item}}</view>
    </view>
  </view>

  <!-- 最近接龙记录 -->
  <view class="card">
    <view class="card-title">📋 最近接龙记录</view>
    <view wx:if="{{loading}}" class="loading">加载中...</view>
    <view wx:if="!loading && records.length === 0" class="empty">暂无记录，录入第一条吧 🏸</view>

    <view class="record-list" wx:if="records.length > 0">
      <view class="record-item" wx:for="{{records}}" wx:key="_id" bindtap="viewRecord" data-record="{{item}}">
        <view class="record-date">{{item.date}}</view>
        <view class="record-signups">{{item.previewText}}</view>
        <view class="record-delete" bindtap="deleteRecord" data-id="{{item._id}}" data-date="{{item.date}}">删除</view>
      </view>
    </view>
  </view>

  <view class="toast {{showToast ? 'toast-show' : ''}}">{{toastMsg}}</view>
</view>
