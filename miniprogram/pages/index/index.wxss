.container {
  padding: 20rpx 30rpx;
  padding-bottom: 120rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.form-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.form-label {
  width: 80rpx;
  font-size: 28rpx;
  color: #666;
}

.picker {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 20rpx;
  border: 2rpx solid #e5e5e5;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  background: #fafafa;
}

.input-area {
  width: 100%;
  min-height: 240rpx;
  padding: 20rpx;
  border: 2rpx solid #e5e5e5;
  border-radius: 12rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
  box-sizing: border-box;
  background: #fafafa;
}

.input-area:focus {
  border-color: #1aad19;
  background: #fff;
}

.btn-row {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  text-align: center;
}

.btn-primary {
  background: #1aad19;
  color: #fff;
}

.btn-outline {
  background: #fff;
  color: #666;
  border: 2rpx solid #ddd;
}

.result-info {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.highlight {
  color: #1aad19;
  font-weight: 600;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tag {
  background: #e8f5e9;
  color: #1aad19;
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
}

.loading, .empty {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  padding: 40rpx 0;
}

.record-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.record-item:last-child { border-bottom: none; }

.record-date {
  font-size: 28rpx;
  font-weight: 600;
  color: #1aad19;
  width: 160rpx;
  flex-shrink: 0;
}

.record-signups {
  flex: 1;
  font-size: 24rpx;
  color: #888;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
  margin: 0 16rpx;
}

.record-delete {
  font-size: 26rpx;
  color: #e64340;
  padding: 8rpx 16rpx;
  flex-shrink: 0;
}

.toast {
  position: fixed;
  bottom: 40%;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0,0,0,0.75);
  color: #fff;
  padding: 16rpx 40rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  opacity: 0;
  transition: opacity 0.3s;
  pointer-events: none;
  z-index: 200;
}

.toast-show { opacity: 1; }
