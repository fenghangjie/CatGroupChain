.container {
  padding: 20rpx 30rpx;
  padding-bottom: 120rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.subtitle {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 24rpx;
}

.loading, .empty {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  padding: 40rpx 0;
}

.player-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.player-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 16rpx;
  border: 2rpx solid #f0f0f0;
  border-radius: 12rpx;
}

.player-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #1aad19, #4cd964);
  color: #fff;
  font-size: 32rpx;
  text-align: center;
  line-height: 72rpx;
  flex-shrink: 0;
}

.player-info {
  flex: 1;
  min-width: 0;
}

.player-nickname {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.player-wxid {
  font-size: 24rpx;
  color: #888;
  margin-top: 4rpx;
}

.player-aliases {
  font-size: 22rpx;
  color: #bbb;
  margin-top: 2rpx;
}

.footer-actions {
  margin-top: 40rpx;
  text-align: center;
}

.btn-danger {
  background: #fff;
  color: #e64340;
  border: 2rpx solid #e64340;
  border-radius: 12rpx;
  font-size: 26rpx;
  height: 72rpx;
  line-height: 72rpx;
}

.toast {
  position: fixed;
  bottom: 40%;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0,0,0,0.75);
  color: #fff;
  padding: 16rpx 40rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  opacity: 0;
  transition: opacity 0.3s;
  pointer-events: none;
  z-index: 200;
}

.toast-show { opacity: 1; }
.collapse-toggle {
  text-align: center;
  padding: 20rpx;
  margin-top: 10rpx;
  font-size: 28rpx;
  color: #1aad19;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.collapse-toggle:active {
  opacity: 0.6;
}

.player-list-collapsed .player-item:nth-child(n+11) {
  display: none;
}

/* Admin management */
.form-row {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.form-input {
  border: 2rpx solid #ddd;
  border-radius: 8rpx;
  padding: 16rpx 20rpx;
  font-size: 26rpx;
  height: auto;
  min-height: 72rpx;
  box-sizing: border-box;
}

.btn-small {
  font-size: 26rpx;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 30rpx;
}

.admin-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.admin-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx;
  border: 2rpx solid #f0f0f0;
  border-radius: 8rpx;
}

.admin-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #333;
  min-width: 80rpx;
}

.admin-openid {
  flex: 1;
  font-size: 22rpx;
  color: #999;
}

.btn-remove {
  background: none;
  border: none;
  color: #e64340;
  font-size: 24rpx;
  padding: 8rpx 16rpx;
}

.btn-remove::after {
  border: none;
}
