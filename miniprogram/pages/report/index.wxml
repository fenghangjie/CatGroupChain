<view class="container">
  <view class="view-switch">
    <view class="switch-btn {{viewMode==='month'?'switch-active':''}}" bindtap="switchView" data-mode="month">📅 月</view>
    <view class="switch-btn {{viewMode==='year'?'switch-active':''}}" bindtap="switchView" data-mode="year">📆 年</view>
  </view>

  <view class="month-picker" wx:if="{{viewMode==='month'}}">
    <view class="month-nav" bindtap="prevMonth">◀</view>
    <view class="month-title">{{year}}年{{month}}月</view>
    <view class="month-nav" bindtap="nextMonth">▶</view>
  </view>
  <view class="month-picker" wx:if="{{viewMode==='year'}}">
    <view class="month-nav" bindtap="prevYear">◀</view>
    <view class="month-title">{{year}}年 年度汇总</view>
    <view class="month-nav" bindtap="nextYear">▶</view>
  </view>

  <view class="summary-card">
    <view class="summary-item">
      <text class="summary-num">{{totalActivities}}</text>
      <text class="summary-label">{{viewMode==='month' ? '本月活动' : '全年活动'}}</text>
    </view>
    <view class="summary-item">
      <text class="summary-num">{{totalPlayers}}</text>
      <text class="summary-label">参与人数</text>
    </view>
    <view class="summary-item">
      <text class="summary-num">{{totalAttendance}}</text>
      <text class="summary-label">{{viewMode==='month' ? '总人次' : '全年人次'}}</text>
    </view>
  </view>

  <view class="card">
    <view class="card-title">🏆 参与排行榜</view>
    <view wx:if="{{loading}}" class="loading">加载中...</view>
    <view wx:if="!loading && report.length === 0" class="empty">暂无数据 🏸</view>
    
    <view class="rank-list" wx:if="report.length > 0">
      <view class="rank-item" wx:for="{{report}}" wx:key="playerId" wx:for-index="i" bindtap="viewPlayer" data-playerid="{{item.playerId}}" data-name="{{item.nickname}}">
        <view class="rank-num rank-{{i < 3 ? ['gold','silver','bronze'][i] : 'normal'}}">
          <text wx:if="{{i < 3}}">{{['🥇','🥈','🥉'][i]}}</text>
          <text wx:else>{{item.rank}}</text>
        </view>
        <view class="rank-name">{{item.nickname}}</view>
        <view class="rank-bar-wrap">
          <view class="rank-bar" style="width: {{maxCount > 0 ? (item.count / maxCount * 100) : 0}}%"></view>
        </view>
        <view class="rank-count">{{item.count}} 次</view>
      </view>
    </view>
  </view>

  <view class="card" wx:if="{{viewMode==='year' && yearReport.length>0}}">
    <view class="card-title">📆 {{year}}年 每月活动</view>
    <view class="year-grid">
      <view class="year-month-item" wx:for="{{yearReport}}" wx:key="month">
        <view class="year-month-name">{{item.monthName}}</view>
        <view class="year-month-count">{{item.count}} 场</view>
        <view class="year-month-attendance">{{item.attendance}} 人次</view>
      </view>
    </view>
  </view>

  <view wx:if="{{loading}}" class="loading">加载中...</view>
</view>