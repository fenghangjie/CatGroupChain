.container {
  padding: 20rpx 30rpx;
  padding-bottom: 120rpx;
}

.month-picker {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 40rpx;
  margin-bottom: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.month-nav {
  font-size: 36rpx;
  color: #1aad19;
  padding: 8rpx 20rpx;
}

.month-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.summary-card {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.summary-item {
  flex: 1;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.summary-num {
  font-size: 44rpx;
  font-weight: 700;
  color: #1aad19;
}

.summary-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

/* 考勤矩阵 */
.matrix-scroll {
  width: 100%;
  overflow-x: auto;
}

.matrix {
  min-width: max-content;
}

.matrix-row {
  display: flex;
  align-items: center;
  border-bottom: 2rpx solid #f5f5f5;
}

.matrix-header {
  background: #f9f9f9;
  font-weight: 600;
}

.matrix-cell {
  padding: 12rpx 8rpx;
  font-size: 24rpx;
  text-align: center;
  flex-shrink: 0;
}

.matrix-name {
  width: 100rpx;
  text-align: left;
  font-weight: 500;
  color: #333;
}

.matrix-day {
  width: 60rpx;
}

.matrix-total {
  width: 70rpx;
  font-weight: 600;
  color: #1aad19;
}

.dot {
  font-size: 24rpx;
}

.dot-yes {
  color: #1aad19;
}

.dot-no {
  color: #ddd;
}

/* 排行榜 */
.rank-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.rank-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 0;
}

.rank-num {
  width: 56rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.rank-gold { color: #f5a623; }
.rank-silver { color: #7a8a9e; }
.rank-bronze { color: #cd7f32; }
.rank-normal { color: #999; }

.rank-name {
  width: 130rpx;
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  flex-shrink: 0;
}

.rank-bar-wrap {
  flex: 1;
  height: 28rpx;
  background: #f0f0f0;
  border-radius: 14rpx;
  overflow: hidden;
}

.rank-bar {
  height: 100%;
  background: linear-gradient(90deg, #b8e6b8, #1aad19);
  border-radius: 14rpx;
  transition: width 0.3s;
}

.rank-count {
  width: 80rpx;
  text-align: right;
  font-size: 26rpx;
  color: #888;
  flex-shrink: 0;
}

.loading, .empty {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  padding: 60rpx 0;
}
