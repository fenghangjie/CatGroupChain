.container {
  padding: 20rpx 30rpx;
  padding-bottom: 120rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.act-info {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
  font-size: 28rpx;
}

.act-label {
  color: #888;
  width: 80rpx;
}

.act-value {
  color: #333;
  font-weight: 500;
}

.input-area {
  width: 100%;
  min-height: 300rpx;
  padding: 20rpx;
  border: 2rpx solid #e5e5e5;
  border-radius: 12rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
  box-sizing: border-box;
  background: #fafafa;
  margin-top: 20rpx;
}

.input-area:focus {
  border-color: #1aad19;
  background: #fff;
}

.btn-row {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  text-align: center;
}

.btn-primary {
  background: #1aad19;
  color: #fff;
}

.btn-outline {
  background: #fff;
  color: #666;
  border: 2rpx solid #ddd;
}

.result-info {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.highlight {
  color: #1aad19;
  font-weight: 600;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tag {
  background: #e8f5e9;
  color: #1aad19;
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
}

.toast {
  position: fixed;
  bottom: 40%;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0,0,0,0.75);
  color: #fff;
  padding: 16rpx 40rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  opacity: 0;
  transition: opacity 0.3s;
  pointer-events: none;
}

.toast-show {
  opacity: 1;
}
